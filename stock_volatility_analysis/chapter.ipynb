import numpy as np
import yfinance as yf
# import os

# os.environ['HTTP_PROXY'] = "http://127.0.0.1:7897"
# os.environ['HTTPS_PROXY'] = "http://127.0.0.1:7897"

# Download AAPL stock data from yfinance
df_yahoo = yf.download("AAPL",
                 start="2010-01-01",
                 end="2020-12-31",
                 auto_adjust=False,
                 progress=False,
                 )

# Convert data to CSV format
df_yahoo.to_csv('appl_2010_2020.csv')

# Keep only Adj Close column and rename it to adj_close
df = df_yahoo.loc[:, ['Adj Close']]
df.rename(columns={'Adj Close': 'adj_close'}, inplace=True)

# Calculate logarithmic returns
df['log_rtn'] = np.log(df.adj_close / df.adj_close.shift(1))

# Drop adj_close column (axis=1 for columns, axis=0 for rows)
df.drop('adj_close',axis=1,inplace=True)
# Drop rows with missing values
df.dropna(axis=0,inplace=True)
# Display first 5 rows
df.head()

import pandas as pd
import matplotlib.pyplot as plt

# Define function to calculate realized volatility
def realized_volatility(x):
    return np.sqrt(np.sum(x**2))

# Group by month and calculate monthly volatility
df_rv = (df.groupby(pd.Grouper(freq='ME')).apply(realized_volatility))

# Rename column
df_rv.rename(columns={'log_rtn': 'rv'}, inplace=True)

# Calculate annual volatility
df_rv.rv = df_rv.rv * np.sqrt(12)

# Plotting: fig is the canvas, ax is subplots. 2 rows 1 column, sharex=True means shared x-axis
fig, ax = plt.subplots(2, 1, sharex=True)
ax[0].plot(df)
ax[1].plot(df_rv)

# Auto-adjust subplot spacing to avoid label overlap
plt.tight_layout()
plt.savefig('week1/ch1_im6.png')
plt.show()